    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================\n// MERGE PROFILE DATA WITH ORIGINAL WEBHOOK DATA\n// Combines IG profile info with the parsed message\n// ============================================\n\nconst profile = $input.item.json;\n\n// Pull the original parsed data from earlier node\nconst parsed = $('Parse Webhook Data').first().json;\n\nreturn {\n  json: {\n    // Original message data\n    eventType: parsed.eventType,\n    myAccountId: parsed.myAccountId,\n    leadIgsid: parsed.leadIgsid,\n    messageText: parsed.messageText,\n    messageMid: parsed.messageMid,\n    timestamp: parsed.timestamp,\n    \n    // Profile data (may be null if user hasn't consented yet)\n    username: profile.username || null,\n    name: profile.name || null,\n    profilePic: profile.profile_pic || null,\n    followerCount: profile.follower_count || 0,\n    isUserFollowBusiness: profile.is_user_follow_business || false,\n    isBusinessFollowUser: profile.is_business_follow_user || false,\n    \n    // Build the Instagram URL if username is available\n    instagramUrl: profile.username ? `https://instagram.com/${profile.username}` : null\n  }\n};"
      },
