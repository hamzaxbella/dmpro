    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================\n// PARSE INSTAGRAM WEBHOOK\n// Normalizes both outbound echoes and inbound messages\n// ============================================\n\nconst body = $input.item.json.body;\nconst entry = body?.entry?.[0];\nconst messaging = entry?.messaging?.[0];\n\n// Skip non-message events (reactions, read receipts, postbacks, etc.)\nif (!messaging?.message) {\n  return { json: { eventType: 'skip' } };\n}\n\nconst isEcho = messaging.message.is_echo === true;\nconst myAccountId = entry.id;\n\n// When YOU send: sender = you, recipient = lead\n// When LEAD replies: sender = lead, recipient = you\nconst leadIgsid = isEcho ? messaging.recipient.id : messaging.sender.id;\n\nreturn {\n  json: {\n    eventType: isEcho ? 'outbound' : 'inbound',\n    myAccountId: myAccountId,\n    leadIgsid: leadIgsid,\n    messageText: messaging.message.text || '',\n    messageMid: messaging.message.mid || '',\n    timestamp: messaging.timestamp,\n    senderId: messaging.sender.id,\n    recipientId: messaging.recipient.id\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
